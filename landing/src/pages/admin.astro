---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base
  title="Админка — MusicTech"
  description="Управление пользователями и системой MusicTech."
>
  <section id="admin-loading" class="container-soft py-24 md:py-32 text-center">
    <div class="inline-flex items-center gap-3 text-ink-500">
      <svg class="animate-spin size-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.2"/>
        <path d="M22 12a10 10 0 0 0-10-10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
      </svg>
      проверяем доступ...
    </div>
  </section>

  <section id="admin-denied" class="container-soft py-24 md:py-32 text-center hidden">
    <h1 class="font-display text-4xl font-bold text-ink-900">403 — нет доступа</h1>
    <p class="mt-3 text-ink-600">
      Эта страница только для администраторов. Если вам нужен доступ —
      <a href="mailto:hello@musictech.tech" class="link">напишите нам</a>.
    </p>
    <a href={`${base}/`} class="btn-primary mt-6 inline-flex">На главную</a>
  </section>

  <section id="admin-app" class="container-soft py-12 md:py-16 hidden">
    <header class="reveal flex items-end justify-between gap-4 flex-wrap mb-8">
      <div>
        <span class="pill bg-red-50 text-red-700 border-red-200">admin</span>
        <h1 class="mt-3 font-display text-4xl md:text-5xl font-bold tracking-tight">
          Панель администратора
        </h1>
        <p class="mt-2 text-ink-600" id="adm-subtitle">
          Загружаем пользователей…
        </p>
      </div>
      <div class="flex items-center gap-2">
        <a href={`${base}/account`} class="btn-ghost">Мой профиль</a>
        <button id="adm-refresh" class="btn-ghost">Обновить</button>
        <button id="adm-create-btn" class="btn-primary">+ Пользователь</button>
      </div>
    </header>

    <div class="reveal grid gap-4 md:grid-cols-3 mb-8">
      <article class="card">
        <div class="text-xs uppercase tracking-wider text-ink-500">всего пользователей</div>
        <div class="mt-2 font-display text-4xl font-bold text-ink-900" id="kpi-total">0</div>
      </article>
      <article class="card">
        <div class="text-xs uppercase tracking-wider text-ink-500">админов</div>
        <div class="mt-2 font-display text-4xl font-bold text-ink-900" id="kpi-admins">0</div>
      </article>
      <article class="card">
        <div class="text-xs uppercase tracking-wider text-ink-500">новых за 7 дней</div>
        <div class="mt-2 font-display text-4xl font-bold text-ink-900" id="kpi-recent">0</div>
      </article>
    </div>

    <div class="reveal card p-0 overflow-hidden">
      <div class="px-5 py-3 border-b border-ink-200 flex items-center gap-2">
        <input id="adm-search" type="search" placeholder="поиск по email или имени…"
          class="flex-1 rounded-lg border border-ink-200 px-3 py-2 text-sm bg-white
                 focus:border-brand-500 focus:ring focus:ring-brand-100 outline-none transition" />
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-ink-50/70 text-ink-500 uppercase text-xs">
            <tr>
              <th class="px-5 py-3 text-left">Имя</th>
              <th class="px-5 py-3 text-left">E-mail</th>
              <th class="px-5 py-3 text-left">План</th>
              <th class="px-5 py-3 text-left">Роль</th>
              <th class="px-5 py-3 text-left">Создан</th>
              <th class="px-5 py-3 text-right">Действия</th>
            </tr>
          </thead>
          <tbody id="users-tbody" class="divide-y divide-ink-100">
            <!-- строки рендерятся JS -->
          </tbody>
        </table>
      </div>
      <div id="users-empty" class="px-5 py-10 text-center text-ink-500 hidden">
        Пользователей пока нет.
      </div>
    </div>
  </section>

  <!-- модалка создания пользователя -->
  <div id="modal-create" class="fixed inset-0 z-50 hidden items-center justify-center bg-ink-900/50 p-4">
    <div class="card max-w-md w-full">
      <h3 class="font-display text-xl font-bold">Создать пользователя</h3>
      <p class="mt-1 text-sm text-ink-600">
        Создаётся сразу активным, без подтверждения e-mail.
      </p>
      <form id="create-form" class="mt-4 space-y-4">
        <label class="block">
          <span class="block text-sm font-semibold text-ink-800 mb-1.5">Имя</span>
          <input name="name" type="text" required minlength="2" maxlength="60"
            class="w-full rounded-xl border border-ink-200 px-4 py-3 text-sm bg-white outline-none" />
        </label>
        <label class="block">
          <span class="block text-sm font-semibold text-ink-800 mb-1.5">E-mail</span>
          <input name="email" type="email" required
            class="w-full rounded-xl border border-ink-200 px-4 py-3 text-sm bg-white outline-none" />
        </label>
        <label class="block">
          <span class="block text-sm font-semibold text-ink-800 mb-1.5">Пароль (≥ 8 символов)</span>
          <input name="password" type="text" required minlength="8"
            class="w-full rounded-xl border border-ink-200 px-4 py-3 text-sm bg-white outline-none font-mono" />
        </label>
        <p id="create-msg" class="msg hidden"></p>
        <div class="flex gap-2 justify-end">
          <button type="button" id="create-cancel" class="btn-ghost">Отмена</button>
          <button type="submit" class="btn-primary">Создать</button>
        </div>
      </form>
    </div>
  </div>

  <script is:inline>
    const loading = document.getElementById("admin-loading");
    const denied  = document.getElementById("admin-denied");
    const app     = document.getElementById("admin-app");

    function authHeaders() {
      const t = localStorage.getItem("musictech.token") || "";
      const h = { "content-type": "application/json" };
      if (t) h.authorization = `Bearer ${t}`;
      return h;
    }

    function show(which) {
      [loading, denied, app].forEach((n) => n.classList.add("hidden"));
      which.classList.remove("hidden");
    }

    function fmtDate(ts) {
      try {
        return new Date(ts).toLocaleString("ru-RU", {
          day: "2-digit", month: "2-digit", year: "numeric",
          hour: "2-digit", minute: "2-digit",
        });
      } catch { return "—"; }
    }

    let state = { users: [], total: 0, query: "" };

    async function loadMe() {
      try {
        const r = await fetch("/api/auth/me", { headers: authHeaders(), credentials: "include" });
        if (r.status === 401) { location.href = location.pathname.replace(/\/admin\/?$/, "") + "/login"; return; }
        const b = await r.json();
        if (!b?.ok) return show(denied);
        if (b.user.role !== "admin") return show(denied);
        await loadUsers();
        show(app);
      } catch { show(denied); }
    }

    async function loadUsers() {
      const r = await fetch("/api/admin/users?limit=500", { headers: authHeaders(), credentials: "include" });
      const b = await r.json();
      if (!r.ok || !b?.ok) {
        document.getElementById("adm-subtitle").textContent = "не удалось загрузить пользователей";
        return;
      }
      state.users = b.users;
      state.total = b.total;
      updateKpi();
      render();
    }

    function updateKpi() {
      document.getElementById("kpi-total").textContent  = state.total;
      const admins = state.users.filter((u) => u.role === "admin").length;
      document.getElementById("kpi-admins").textContent = admins;
      const weekAgo = Date.now() - 7 * 24 * 3600 * 1000;
      const recent = state.users.filter((u) => u.createdAt >= weekAgo).length;
      document.getElementById("kpi-recent").textContent = recent;
      document.getElementById("adm-subtitle").textContent =
        `${state.total} пользователь(ей) в системе`;
    }

    function render() {
      const tbody = document.getElementById("users-tbody");
      const q = state.query.toLowerCase();
      const filtered = q
        ? state.users.filter((u) => (u.email + " " + (u.name || "")).toLowerCase().includes(q))
        : state.users;
      tbody.innerHTML = "";
      if (filtered.length === 0) {
        document.getElementById("users-empty").classList.remove("hidden");
        return;
      }
      document.getElementById("users-empty").classList.add("hidden");
      for (const u of filtered) {
        const tr = document.createElement("tr");
        tr.className = "hover:bg-ink-50/60";
        tr.innerHTML = `
          <td class="px-5 py-3 font-medium text-ink-900">${escapeHtml(u.name || "—")}</td>
          <td class="px-5 py-3 text-ink-700">${escapeHtml(u.email)}</td>
          <td class="px-5 py-3"><span class="pill text-xs">${escapeHtml(u.plan || "open-beta")}</span></td>
          <td class="px-5 py-3">${
            u.role === "admin"
              ? '<span class="pill bg-red-50 text-red-700 border-red-200 text-xs">admin</span>'
              : '<span class="text-ink-500 text-xs">user</span>'
          }</td>
          <td class="px-5 py-3 text-ink-500 text-xs">${fmtDate(u.createdAt)}</td>
          <td class="px-5 py-3 text-right">
            <button data-action="delete" data-email="${escapeHtml(u.email)}"
              class="text-red-600 hover:text-red-800 text-xs font-semibold">
              удалить
            </button>
          </td>
        `;
        tbody.appendChild(tr);
      }
    }

    document.getElementById("users-tbody").addEventListener("click", async (e) => {
      const btn = e.target.closest("button[data-action='delete']");
      if (!btn) return;
      const email = btn.dataset.email;
      if (!confirm(`удалить ${email}? это действие нельзя отменить.`)) return;
      const r = await fetch("/api/admin/users", {
        method: "DELETE", headers: authHeaders(), credentials: "include",
        body: JSON.stringify({ email }),
      });
      const b = await r.json();
      if (!r.ok || !b?.ok) { alert(b?.error || "не удалось удалить"); return; }
      await loadUsers();
    });

    document.getElementById("adm-search").addEventListener("input", (e) => {
      state.query = e.currentTarget.value;
      render();
    });
    document.getElementById("adm-refresh").addEventListener("click", loadUsers);

    // создание
    const modal = document.getElementById("modal-create");
    const createForm = document.getElementById("create-form");
    const createMsg  = document.getElementById("create-msg");
    document.getElementById("adm-create-btn").addEventListener("click", () => {
      createForm.reset(); createMsg.classList.add("hidden");
      modal.classList.remove("hidden"); modal.classList.add("flex");
    });
    document.getElementById("create-cancel").addEventListener("click", () => {
      modal.classList.add("hidden"); modal.classList.remove("flex");
    });
    createForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const data = new FormData(createForm);
      const body = {
        name:     String(data.get("name")     || "").trim(),
        email:    String(data.get("email")    || "").trim(),
        password: String(data.get("password") || ""),
      };
      createMsg.classList.add("hidden");
      const r = await fetch("/api/admin/users", {
        method: "POST", headers: authHeaders(), credentials: "include",
        body: JSON.stringify(body),
      });
      const b = await r.json();
      if (!r.ok || !b?.ok) {
        createMsg.textContent = b?.error || `ошибка ${r.status}`;
        createMsg.className = "msg text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2";
        return;
      }
      modal.classList.add("hidden"); modal.classList.remove("flex");
      await loadUsers();
    });

    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c] || c);
    }

    loadMe();
  </script>
</Base>
